<?xml version="1.0" ?>
<sdf version="1.8">
    <world name="cart_pole_sim">

        <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics" />
        <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands" />
        <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster" />
        

        <physics name="1ms" type="ode">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>

        <include>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Sun</uri>
        </include>
        <include>
            <uri>https://fuel.gazebosim.org/1.0/openrobotics/models/Ground Plane</uri>
        </include>

        <model name="cart_pole">
            <plugin filename="libcontroller.so" name="controller"/>

            <pose>0 0 4 0 0 0</pose>
            <!-- CART LINK AND JOINT-->
            <link name="cart">
                <inertial>
                    <mass>2.0</mass>
                    <inertia>
                        <ixx>0.037</ixx><iyy>0.021</iyy><izz>0.037</izz>
                    </inertia>
                </inertial>
                <visual name="v1">
                    <geometry><box><size>0.25 0.4 0.25</size></box></geometry>
                </visual>
                <collision name="c1">
                    <geometry><box><size>0.25 0.4 0.25</size></box></geometry>
                </collision>
            </link>

            
            <joint name="cart_linear" type="prismatic">
                <parent>world</parent>
                <child>cart</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit>
                        <lower>-15.0</lower>
                        <upper>15.0</upper>
                    </limit>
                    <dynamics>
                        <damping>0.5</damping>
                        <friction>0.1</friction>
                    </dynamics>
                </axis>
            </joint>

            <!-- POLE LINK AND JOINT -->
            <link name="pole">
                <pose relative_to="cart">-0.125 0 0 0 0 0</pose>

                <inertial>
                    <pose>0 0 0.5 0 0 0</pose>
                    <mass>0.2</mass>
                    <inertia>
                        <ixx>0.0167</ixx>
                        <iyy>0.0167</iyy>
                        <izz>0.001</izz>
                    </inertia>
                </inertial>

                <visual name="v2">
                    <pose>0 0 0.5 0 0 0</pose>
                    <geometry>
                    <box>
                        <size>0.05 0.05 1.0</size>
                    </box>
                    </geometry>
                    <material>
                        <diffuse>1 0 0 1</diffuse>
                        <ambient>1 0 0 1</ambient>
                    </material>
                </visual>

                <collision name="c2">
                    <pose>0 0 0.5 0 0 0</pose>
                    <geometry>
                    <box>
                        <size>0.05 0.05 1.0</size>
                    </box>
                    </geometry>
                </collision>
            </link>

            <joint name="pole_revolute" type="revolute">
                <parent>cart</parent>
                <child>pole</child>
                <pose relative_to="cart">-0.125 0 0 0 0 0</pose>
                <axis>
                    <xyz>1 0 0</xyz>
                    <dynamics>
                        <damping>0.01</damping>
                    </dynamics>
                </axis>
            </joint>
        </model>
    </world>
</sdf>
